{
    "name": "arielespinoza07/result-pattern",
    "description": "A modern implementation of the Result pattern for handling operation outcomes in PHP 8.3+",
    "keywords": ["php", "result-pattern", "outcome"],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Ariel Espinoza",
            "email": "arielespinoza46@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "pestphp/pest": "^4.4.1",
        "phpstan/phpstan": "^2.1.40",
        "laravel/pint": "^1.27.1",
        "pestphp/pest-plugin-type-coverage": "^4.0.3"
    },
    "autoload": {
        "psr-4": {
            "ArielEspinoza07\\ResultPattern\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint": "pint --test",
        "lint:fix": "pint",
        "analyse": "phpstan analyse",
        "test": "pest",
        "test:coverage": "pest --coverage",
        "check": [
            "@lint",
            "@analyse",
            "@test"
        ]
    },
    "minimum-stability": "stable",
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
